{
  "name": "@winm2m/inferential-stats-js",
  "version": "1.5.0",
  "description": "A headless JavaScript SDK for advanced statistical analysis in the browser using WebAssembly (Pyodide). Performs SPSS-level inferential statistics entirely client-side with no backend required.",
  "author": "Youngjune Kwon <yjkwon@winm2m.com>",
  "license": "MIT",
  "keywords": [
    "statistics",
    "inferential-statistics",
    "pyodide",
    "webassembly",
    "wasm",
    "spss",
    "anova",
    "t-test",
    "regression",
    "factor-analysis",
    "pca",
    "clustering",
    "chi-square",
    "cronbach-alpha",
    "web-worker",
    "browser"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/WinM2M/inferential-stats-js.git"
  },
  "homepage": "https://github.com/WinM2M/inferential-stats-js#readme",
  "bugs": {
    "url": "https://github.com/WinM2M/inferential-stats-js/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./worker": "./dist/stats-worker.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "rollup -c",
    "build:types": "tsc --emitDeclarationOnly --declaration --outDir dist",
    "dev": "rollup -c -w",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "generate-data": "node scripts/generate-mock-data.js",
    "pretest": "npm run build",
    "test": "vitest",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "pretest:ci": "npm run build",
    "test:ci": "vitest run",
    "docs": "typedoc",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-typescript": "^12.1.2",
    "@types/jest": "^30.0.0",
    "@vitest/browser": "^3.2.4",
    "jest": "^30.3.0",
    "playwright": "^1.54.2",
    "rollup": "^4.34.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.0",
    "typedoc": "^0.28.18",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "pyodide": ">=0.26.0"
  },
  "peerDependenciesMeta": {
    "pyodide": {
      "optional": true
    }
  },
  "dependencies": {
    "sav-reader": "^2.0.8"
  }
}
